<?xml version="1.0" encoding="UTF-8"?>
<website name="GIAPTECH" url="https://giaptech.site" lang="vi">

  <!-- ═══════════════════════════════════════════
       1. DESIGN TOKENS
  ═══════════════════════════════════════════ -->
  <design_tokens>
    <colors>
      <token name="--b50"  value="#eff6ff" usage="Background nhạt, badge, input bg"/>
      <token name="--b100" value="#dbeafe" usage="Border nhẹ, divider"/>
      <token name="--b200" value="#bfdbfe" usage="Border card, input border"/>
      <token name="--b300" value="#93c5fd" usage="Border hover"/>
      <token name="--b400" value="#60a5fa" usage="Logo, footer accent"/>
      <token name="--b500" value="#3b82f6" usage="Primary blue, gradient start"/>
      <token name="--b600" value="#2563eb" usage="Link, btn text, strong accent"/>
      <token name="--b700" value="#1d4ed8" usage="Gradient end, dark accent"/>
      <token name="--navy" value="#0f172a" usage="Heading text"/>
      <token name="--slate" value="#1e293b" usage="Body text chính"/>
      <token name="--muted" value="#64748b" usage="Text phụ, description"/>
      <token name="--light" value="#94a3b8" usage="Placeholder, meta text"/>
      <token name="--white" value="#ffffff" usage="Background chính"/>
    </colors>
    <typography>
      <font name="Be Vietnam Pro" weights="400,500,600,700,800,900" source="Google Fonts"/>
      <font name="system-ui" role="fallback"/>
      <scale>
        <size role="h1-hero"     value="clamp(2rem, 4vw, 3.4rem)" weight="900" lineHeight="1.15"/>
        <size role="h2-section"  value="clamp(1.8rem, 3.2vw, 2.8rem)" weight="900" lineHeight="1.2"/>
        <size role="h3-card"     value="1rem" weight="700"/>
        <size role="body"        value="1rem" lineHeight="1.65"/>
        <size role="body-small"  value="0.9rem" lineHeight="1.7"/>
        <size role="label"       value="0.82rem" weight="700"/>
        <size role="caption"     value="0.8rem"/>
        <size role="nav-link"    value="0.88rem" weight="600"/>
      </scale>
    </typography>
    <spacing>
      <token name="section-padding"  value="7rem 0"/>
      <token name="container-max"    value="1400px"/>
      <token name="container-padding" value="0 4%"/>
      <token name="border-radius"    value="16px (--r)"/>
      <token name="border-radius-btn" value="12px"/>
      <token name="border-radius-pill" value="30px"/>
    </spacing>
    <shadows>
      <token name="--sh"  value="0 4px 24px rgba(37,99,235,.10)"  usage="Card hover nhẹ"/>
      <token name="--sh2" value="0 16px 48px rgba(37,99,235,.16)" usage="Card hover mạnh, form"/>
    </shadows>
    <animations>
      <token name="fadeUp"       keyframes="opacity 0→1, translateY 30px→0" duration="0.9s"/>
      <token name="orb"          keyframes="translate(0,0)→translate(20px,-20px)" duration="10-13s" infinite="true"/>
      <token name="ping"         keyframes="scale 1→1.3, opacity 1→0.6" duration="1.5s" infinite="true"/>
      <token name="pulseShadow"  keyframes="box-shadow 0→10px blue spread" duration="2.5s" infinite="true"/>
      <token name="rippleAnim"   keyframes="scale 0→4, opacity→0" duration="0.55s"/>
      <token name="section-reveal" property="opacity+translateY" trigger="IntersectionObserver" threshold="0.15"/>
    </animations>
  </design_tokens>

  <!-- ═══════════════════════════════════════════
       2. LAYOUT STRUCTURE
  ═══════════════════════════════════════════ -->
  <layout>
    <page_structure>
      <block order="1" tag="nav"     id="nav"      position="fixed top-0"/>
      <block order="2" tag="section" id="hero"     height="100vh"/>
      <block order="3" tag="section" id="benefits" bg="white"/>
      <block order="4" tag="section" id="features" bg="white"/>
      <block order="5" tag="section" id="process"  bg="--b50"/>
      <block order="6" tag="section" id="services" bg="white"/>
      <block order="7" tag="section" id="pricing"  bg="--b50"/>
      <block order="8" tag="section" id="contact"  bg="white"/>
      <block order="9" tag="footer"  bg="--navy"/>
      <float type="button" id="scroll-top" position="fixed bottom-right" trigger="scrollY > 500"/>
    </page_structure>

    <grid_systems>
      <grid id="hero-inner"    cols="1fr 1fr"         gap="4rem"  breakpoint_collapse="1024px"/>
      <grid id="benefits-grid" cols="repeat(auto-fit,minmax(300px,1fr))" gap="1.5rem"/>
      <grid id="features-grid" cols="repeat(auto-fit,minmax(300px,1fr))" gap="1.5rem"/>
      <grid id="services-grid" cols="repeat(auto-fit,minmax(300px,1fr))" gap="1.5rem"/>
      <grid id="pricing-grid"  cols="flex wrap justify-center"   gap="2rem" card_width="320px"/>
      <grid id="contact-grid"  cols="1fr 1.2fr"       gap="3rem"  breakpoint_collapse="768px"/>
      <grid id="mock-cards"    cols="repeat(3,1fr)"   gap="0.7rem"/>
    </grid_systems>
  </layout>

  <!-- ═══════════════════════════════════════════
       3. COMPONENTS
  ═══════════════════════════════════════════ -->
  <components>

    <!-- NAV -->
    <component name="Navbar" class="nav">
      <props>
        <prop name="position"    value="fixed top:0 left:0 right:0"/>
        <prop name="background"  value="rgba(255,255,255,.96) + backdrop-filter:blur(16px)"/>
        <prop name="border"      value="bottom 1px solid --b100"/>
        <prop name="zIndex"      value="200"/>
        <prop name="padding"     value="1rem 5%"/>
      </props>
      <children>
        <child tag="div"  class="logo"       content="⚡ GIAPTECH" style="font-size:1.25rem font-weight:900 color:--b600"/>
        <child tag="ul"   class="nav-links"  note="hidden on mobile, toggled by hamburger">
          <item href="#benefits">Lợi ích</item>
          <item href="#features">Tiêu chuẩn</item>
          <item href="#process">Quy trình</item>
          <item href="#services">Dành cho ai</item>
          <item href="#pricing">Bảng giá</item>
        </child>
        <child tag="div"  class="nav-right">
          <cta href="#contact" class="btn-primary nav-cta">Tư vấn miễn phí</cta>
          <button class="hamburger" note="visible mobile only" aria="menu toggle"/>
        </child>
      </children>
    </component>

    <!-- HERO -->
    <component name="Hero" class="hero">
      <props>
        <prop name="minHeight"   value="100vh"/>
        <prop name="background"  value="linear-gradient(145deg, --b50 0%, #f0f9ff 40%, #e0f2fe 100%)"/>
        <prop name="padding"     value="7rem 5% 5rem"/>
        <prop name="overflow"    value="hidden"/>
      </props>
      <effects>
        <effect name="Particles" type="canvas" count="40" color="rgba(59,130,246,alpha)" animation="float"/>
        <effect name="Orb1" size="700px" position="top:-200px right:-150px" animation="orb 10s"/>
        <effect name="Orb2" size="500px" position="bottom:-150px left:-100px" animation="orb 13s reverse"/>
      </effects>
      <children>
        <col class="hero-content" animation="fadeUp 0.9s">
          <child class="hero-badge">
            <dot class="badge-dot" animation="ping"/>
            <text>Bệ Phóng Thương Hiệu Cá Nhân Chuyên Nghiệp</text>
          </child>
          <child tag="h1">Năng lực của bạn xứng đáng được trả giá cao hơn.<br/>Đừng để khách hàng chọn đối thủ chỉ vì họ có vẻ ngoài bóng bẩy hơn.</child>
          <child class="hero-desc">Mô tả ngắn về dịch vụ</child>
          <child class="hero-actions">
            <btn class="btn-hero-primary" animation="pulseShadow">Phân Tích Thương Hiệu Miễn Phí (Trị giá 2Tr) →</btn>
            <btn class="btn-hero-ghost">Xem Cách Chúng Tôi Đột Phá Doanh Thu</btn>
          </child>
          <child class="hero-stats" style="glass-card flex gap">
            <stat label="Chuyên gia tin dùng" value="50+" animated="true"/>
            <stat label="Tăng tỷ lệ chốt sale" value="98%" animated="true"/>
            <stat label="Tốc độ tải trang" value="&lt;2s"/>
            <stat label="Đồng hành hỗ trợ" value="24/7"/>
          </child>
        </col>
        <col class="hero-visual" animation="fadeUp 0.9s 0.3s" hidden_mobile="true">
          <child class="mockup" style="white card with shadow">
            <bar class="mockup-bar" dots="red yellow green"/>
            <content class="mockup-content">
              <div class="mock-nav"/>
              <div class="mock-hero" style="gradient bg with skeleton title/sub/btn"/>
              <div class="mock-cards" style="3-col grid of skeleton cards"/>
            </content>
          </child>
        </col>
      </children>
    </component>

    <!-- BENEFITS -->
    <component name="BenefitsSection" class="benefits-section section" id="benefits">
      <header align="center">
        <label>Tại Sao Bắt Buộc Phải Có Landing Page Cá Nhân?</label>
        <h2>6 Lý Do Website Cá Nhân Sẽ Thay Đổi Hoàn Toàn<br/><gradient>Cách Bạn Kiếm Tiền</gradient></h2>
      </header>
      <grid class="benefits-grid" cols="3" items="6">
        <card class="benefit-card" interaction="TiltCard 3D hover">
          <icon size="52px" bg="--b50" radius="12px"/>
          <h3>Title</h3>
          <p>Description</p>
        </card>
      </grid>
      <cta_bar class="benefits-cta" style="gradient bg flex justify-between">
        <text>🏆 Nhân hiệu mạnh = Khách hàng VIP = Thu nhập đột phá...</text>
        <btn class="btn-primary">Bắt Đầu Xây Dựng Ngay →</btn>
      </cta_bar>
    </component>

    <!-- FEATURES -->
    <component name="FeaturesSection" class="features-section section" id="features">
      <header align="center">
        <label>Tiêu Chuẩn GIAPTECH</label>
        <h2>Không Chỉ Là Web Đẹp,<br/><gradient>Chúng Tôi Xây Dựng "Cỗ Máy In Tiền"</gradient></h2>
      </header>
      <grid class="features-grid" cols="3" items="5">
        <card class="feature-card" interaction="TiltCard 3D hover" animation="fadeUp delay">
          <icon size="52px" bg="--b50" radius="12px"/>
          <h3>Title</h3>
          <p>Description</p>
        </card>
      </grid>
    </component>

    <!-- PROCESS -->
    <component name="ProcessSection" class="process-section section" id="process">
      <header align="center">
        <label>Quy trình làm việc</label>
        <h2>Thực Thi Tốc Độ —<br/><gradient>Minh Bạch Từng Bước</gradient></h2>
      </header>
      <list class="steps" maxWidth="700px" margin="0 auto">
        <step layout="horizontal" items="5">
          <left class="step-left">
            <circle class="step-num" style="gradient blue 48px"/>
            <line class="step-line" style="2px vertical --b200" note="hidden on last item"/>
          </left>
          <right class="step-card" style="white card border hover-translateX(6px)">
            <emoji class="step-icon"/>
            <h3>Title</h3>
            <p>Description</p>
          </right>
        </step>
      </list>
    </component>

    <!-- SERVICES -->
    <component name="ServicesSection" class="services-section section" id="services">
      <header align="center">
        <label>Dịch Vụ Này Dành Riêng Cho Ai?</label>
        <h2>Chúng Tôi Là "Vũ Khí Bí Mật" Của<br/><gradient>Những Chuyên Gia Đứng Đầu Ngành</gradient></h2>
      </header>
      <grid class="services-grid" cols="3" items="6">
        <card class="service-card" interaction="TiltCard 3D hover" layout="flex-col">
          <emoji class="service-icon" size="2.2rem"/>
          <h3>Title</h3>
          <p>Description flex-grow</p>
          <link class="service-link" color="--b600">Tư vấn cho tôi →</link>
        </card>
      </grid>
    </component>

    <!-- PRICING -->
    <component name="PricingSection" class="pricing-section section" id="pricing">
      <header align="center">
        <label>Đầu Tư Nhỏ, Vị Thế Lớn</label>
        <h2>Bảng Giá Minh Bạch —<br/><gradient>Tương Xứng Với Tầm Vóc Của Bạn</gradient></h2>
        <note>Đừng đốt tiền rải tờ rơi...</note>
      </header>
      <list class="pricing-grid" layout="flex wrap center" items="3">
        <card class="pricing-card" width="320px" variants="normal | featured(scale:1.04 border:--b500)">
          <badge class="featured-badge" position="absolute top:-14px center" style="gradient pill">⭐ GIẢI PHÁP TỐI ƯU NHẤT</badge>
          <header>
            <h3>Package name</h3>
            <p class="pkg-desc">Description</p>
          </header>
          <price>
            <span class="price" style="2.2rem font-weight:900 --b600">X.XXX.XXXđ</span>
            <span class="price-note">Bàn giao X ngày</span>
          </price>
          <ul class="pkg-features">
            <li class="ok">✓ Included feature</li>
            <li class="no">✕ Excluded feature</li>
          </ul>
          <btn class="btn-primary | btn-outline">Tư vấn gói này →</btn>
        </card>
      </list>
    </component>

    <!-- CONTACT -->
    <component name="ContactSection" class="contact-section section" id="contact">
      <header align="center">
        <label>Bắt Đầu Kỷ Nguyên Mới Cho Thương Hiệu</label>
        <h2>Nhận Lộ Trình Xây Dựng Nhân Hiệu<br/><gradient>Hoàn Toàn Miễn Phí</gradient></h2>
        <p>Dành 15 phút nói chuyện với chuyên gia...</p>
      </header>
      <grid class="contact-grid" cols="1fr 1.2fr">
        <col class="contact-left">
          <h3>Liên hệ ngay</h3>
          <link class="contact-method" href="tel:..." style="flex card hover-translateX(5px)">
            <emoji>📞</emoji>
            <div><strong>Gọi điện trực tiếp</strong><span>0352 425 290</span></div>
            <arrow>→</arrow>
          </link>
          <link class="contact-method" href="zalo:..." style="flex card hover-translateX(5px)">
            <emoji>💬</emoji>
            <div><strong>Chat Zalo ngay</strong><span>0352 425 290</span></div>
            <arrow>→</arrow>
          </link>
          <div class="response-time" style="flex card --b50">
            <emoji>⏰</emoji>
            <p>Phản hồi tốc độ trong 30 phút — 8:00-22:00</p>
          </div>
        </col>
        <col>
          <form class="contact-form" style="white card shadow padding:2.5rem">
            <h3>Để lại thông tin</h3>
            <input type="text"   placeholder="Họ và tên chuyên gia" required="true"/>
            <input type="tel"    placeholder="Số điện thoại / Zalo" required="true"/>
            <select placeholder="Lĩnh vực chuyên môn" required="true">
              <option>Huấn luyện viên PT / Yoga</option>
              <option>Giáo viên / Chuyên gia Đào tạo</option>
              <option>Môi giới Bất động sản</option>
              <option>Môi giới Xe ô tô</option>
              <option>Chuyên viên Tài chính / Bảo hiểm</option>
              <option>Chuyên gia Thẩm mỹ / Spa</option>
              <option>Lĩnh vực khác</option>
            </select>
            <btn class="btn-primary btn-full">Đăng ký nhận lộ trình miễn phí 🚀</btn>
            <note>🔒 Thông tin được bảo mật tuyệt đối</note>
            <success_state>
              <emoji>🎉</emoji>
              <h3>Đã nhận thông tin của bạn!</h3>
              <p>Chuyên gia GIAPTECH sẽ liên hệ lại trong vòng 30 phút.</p>
            </success_state>
          </form>
        </col>
      </grid>
    </component>

    <!-- FOOTER -->
    <component name="Footer" class="footer" bg="--navy">
      <inner class="footer-inner" layout="flex justify-between" maxWidth="1200px">
        <col class="footer-brand">
          <logo>⚡ GIAPTECH</logo>
          <p>Bệ phóng thương hiệu cá nhân số 1 cho chuyên gia Việt</p>
        </col>
        <col class="footer-contact" align="right">
          <p>📞 0352 425 290</p>
          <p>💬 Zalo: 0352 425 290</p>
          <p>🌐 giaptech.site</p>
        </col>
      </inner>
      <bottom>© 2026 GIAPTECH. All rights reserved.</bottom>
    </component>

    <!-- FLOATING ELEMENTS -->
    <component name="ScrollTopButton" class="scroll-top" position="fixed bottom:2rem right:2rem">
      <trigger>window.scrollY > 500</trigger>
      <style>48px circle gradient-blue shadow</style>
      <content>↑</content>
    </component>

    <!-- REUSABLE MICRO-COMPONENTS -->
    <component name="TiltCard" type="interactive-wrapper">
      <behavior>onMouseMove: perspective(600px) rotateY rotateX translateY(-4px)</behavior>
      <behavior>onMouseLeave: reset transform</behavior>
      <transition>0.15s ease</transition>
    </component>

    <component name="RippleBtn" type="button-or-anchor">
      <behavior>onClick: inject .ripple span, animate scale(0→4) opacity(→0) 0.55s</behavior>
      <variants>href (renders as a) | type=submit (renders as button)</variants>
    </component>

    <component name="Counter" type="animated-number">
      <trigger>IntersectionObserver threshold 0.5</trigger>
      <behavior>count from 0 to target over ~1.8s</behavior>
    </component>

    <component name="Particles" type="canvas-background">
      <config count="40" color="rgba(59,130,246,0.1-0.5)" radius="1-3px" speed="0.4"/>
      <behavior>bounce off edges, requestAnimationFrame loop</behavior>
    </component>

  </components>

  <!-- ═══════════════════════════════════════════
       4. RESPONSIVE BREAKPOINTS
  ═══════════════════════════════════════════ -->
  <responsive>
    <breakpoint max="1024px">
      <change>hero-inner: 2-col → 1-col, text-align center</change>
      <change>hero-visual: hidden</change>
      <change>why-compare: grid 3-col → 1-col, vs hidden</change>
    </breakpoint>
    <breakpoint max="768px">
      <change>nav-links: hidden, toggled by hamburger</change>
      <change>nav-cta: hidden</change>
      <change>pricing-card: width 100% max-width 380px, featured scale removed</change>
      <change>contact-grid: 2-col → 1-col</change>
      <change>footer-contact: text-align left</change>
    </breakpoint>
    <breakpoint max="480px">
      <change>hero: padding reduced</change>
      <change>hero-actions: flex-direction column, stretch</change>
      <change>hero-stats: padding/font reduced</change>
    </breakpoint>
  </responsive>

</website>
